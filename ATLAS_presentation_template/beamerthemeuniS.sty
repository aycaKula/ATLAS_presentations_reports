% Automatic final slide using presenter information
\newcommand{\finalslide}{
  % Count the number of presenters and store their numbers
  \newcounter{presentercounter}
  \setcounter{presentercounter}{0}
  \newcounter{authorlooptemp}
  \setcounter{authorlooptemp}{1}
  \def\firstpresenternum{}
  \def\secondpresenternum{}
  \def\thirdpresenternum{}
  \def\fourthpresenternum{}

  % Loop through authors to count presenters and store their numbers
  \loop
    \ifcsname author@\arabic{authorlooptemp}@presenter\endcsname
      \edef\checkpresenter{\csname author@\arabic{authorlooptemp}@presenter\endcsname}
      \ifthenelse{\equal{\checkpresenter}{true}}{
        \stepcounter{presentercounter}
        \ifnum\value{presentercounter}=1
          \edef\firstpresenternum{\arabic{authorlooptemp}}
        \fi
        \ifnum\value{presentercounter}=2
          \edef\secondpresenternum{\arabic{authorlooptemp}}
        \fi
        \ifnum\value{presentercounter}=3
          \edef\thirdpresenternum{\arabic{authorlooptemp}}
        \fi
        \ifnum\value{presentercounter}=4
          \edef\fourthpresenternum{\arabic{authorlooptemp}}
        \fi
      }{}
    \else
      \setcounter{authorlooptemp}{10} % break if no more authors
    \fi
    \stepcounter{authorlooptemp}
    \ifnum\value{authorlooptemp}<10
  \repeat

  % Debug output
  \typeout{DEBUG: Found \arabic{presentercounter} presenters}
  \typeout{DEBUG: First presenter number: \firstpresenternum}
  \typeout{DEBUG: Second presenter number: \secondpresenternum}
  \typeout{DEBUG: Third presenter number: \thirdpresenternum}
  \typeout{DEBUG: Fourth presenter number: \fourthpresenternum}

  % Select appropriate slide layout based on presenter count
  \typeout{DEBUG: presentercounter = \arabic{presentercounter}}
  \ifnum\value{presentercounter}=0
    \PackageError{beamerthemeuniS}{No presenter defined}{Please define at least one author with presenter=true}
  \fi
  \ifnum\value{presentercounter}=1
    \typeout{DEBUG: Using single presenter mode}
    \finalslideoneauthor{\firstpresenternum}
  \fi
  \ifnum\value{presentercounter}=2
    \typeout{DEBUG: Using two presenter mode}
    \finalslidetwoauthors{\firstpresenternum}{\secondpresenternum}
  \fi
  \ifnum\value{presentercounter}=3
    \typeout{DEBUG: Using three presenter mode - falling back to two presenter layout}
    \PackageWarning{beamerthemeuniS}{Three presenters detected, using two-presenter layout with first two presenters}
    \finalslidethreeauthors{\firstpresenternum}{\secondpresenternum}{\thirdpresenternum}
  \fi
  \ifnum\value{presentercounter}=4
    \typeout{DEBUG: Using four presenter mode - falling back to two presenter layout}
    \PackageWarning{beamerthemeuniS}{Four presenters detected, using two-presenter layout with first two presenters}
    \finalslidefourauthors{\firstpresenternum}{\secondpresenternum}{\thirdpresenternum}{\fourthpresenternum}
  \fi
  \ifnum\value{presentercounter}>4
    \typeout{DEBUG: Too many presenters - falling back to single presenter layout}
    \PackageWarning{beamerthemeuniS}{More than 4 presenters detected (\arabic{presentercounter}), using single-presenter layout with first presenter}
    \finalslideoneauthor{\firstpresenternum}
  \fi
}


