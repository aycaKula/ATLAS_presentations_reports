\newlength{\sectiontitlewidth}
\newlength{\shorttitlewidth}

% Section frame Option A
\newcommand{\sectionframeA}[2]{
	\section{#1}
  \begin{frame}
	  \settowidth{\sectiontitlewidth}{\bfseries\LARGE#1}
		\settowidth{\shorttitlewidth}{\small#2}

    \begin{tikzpicture}[overlay, remember picture]
      \shade[
          top color=General,
          bottom color=General,
          shading angle=-45,
          %opacity=.8
      ]
      (current page.north west) rectangle (current page.south east);

      \node[anchor=center] at (current page.center) {
      \begin{tikzpicture}
        % red circle
        \fill[AreaAred] (\textwidth*0.38, -\textheight*0.2) circle (0.7cm);
        % green circle
        \fill[AreaBgreen] (\textwidth*0.5, -\textheight*0.2) circle (0.7cm);
        % blue circle
        \fill[AreaCblue] (\textwidth*0.62, -\textheight*0.2) circle (0.7cm);

        % Section title
        \node[anchor=center, text=General, color=white, font=\bfseries\LARGE, inner sep = 0, outer sep = 0] at (\textwidth*0.5, \textheight*0) {#1};

			  % Short presentation title
        \node[anchor=center, text=General, color=white, font=\small, inner sep = 0, outer sep = 0] at (\textwidth*0.5 - \sectiontitlewidth/2 + \shorttitlewidth/2, \textheight*0.1) {#2};
      \end{tikzpicture}
      };
    \end{tikzpicture}
  \end{frame}
}

% Section frame Option B
\newcommand{\sectionframeB}[2]{
	\section{#1}
  \begin{frame}
	  \settowidth{\sectiontitlewidth}{\bfseries\LARGE#1}
		\settowidth{\shorttitlewidth}{\small#2}

    \begin{tikzpicture}[overlay, remember picture]
      \shade[
          top color=General,
          bottom color=General,
      ]
      (current page.north west) rectangle (current page.south east);

      % Section title
      \node[anchor=center, text=General, color=white, font=\bfseries\LARGE] at (current page.center) {#1};

			% Short presentation title
      \node[anchor=center, text=General, color=white, font=\small] at ($ (current page.center) + (-\sectiontitlewidth/2 + \shorttitlewidth/2, 0.1\textheight) $) {#2};
    \end{tikzpicture}
  \end{frame}
}

