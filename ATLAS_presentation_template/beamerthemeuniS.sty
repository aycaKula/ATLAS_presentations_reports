% Enhanced author management system with institute numbering
\newcounter{authorcount}
\setcounter{authorcount}{0}
\newcounter{institutecount}
\setcounter{institutecount}{0}

% Store all author information and institute mapping
\newcommand{\allauthors}{}
\newcommand{\allinstitutes}{}
\newcommand{\presenterinfo}{}

% Enhanced authorinfo command
\NewDocumentCommand{\authorinfo}{m m m m m m m m}{
  \stepcounter{authorcount}

  % Simple institute assignment without loop
  \xdef\currentinstnum{0}

  % Check manually for first few institutes (covers most use cases)
  \edef\newinst{#3}

  % Debug: show current state
  \typeout{DEBUG: Processing institute "#3"}
  \typeout{DEBUG: Current institute count: \theinstitutecount}

  % Check institute 1
  \ifnum\theinstitutecount>0
    \expandafter\edef\expandafter\tempinst\expandafter{\csname institute@1\endcsname}
    \typeout{DEBUG: Comparing with institute 1: "\tempinst"}
    \ifx\tempinst\newinst
      \xdef\currentinstnum{1}
      \typeout{DEBUG: Found match at institute 1}
    \fi
  \fi

  % Check institute 2
  \ifnum\currentinstnum=0
    \ifnum\theinstitutecount>1
      \expandafter\edef\expandafter\tempinst\expandafter{\csname institute@2\endcsname}
      \typeout{DEBUG: Comparing with institute 2: "\tempinst"}
      \ifx\tempinst\newinst
        \xdef\currentinstnum{2}
        \typeout{DEBUG: Found match at institute 2}
      \fi
    \fi
  \fi

  % Check institute 3
  \ifnum\currentinstnum=0
    \ifnum\theinstitutecount>2
      \expandafter\edef\expandafter\tempinst\expandafter{\csname institute@3\endcsname}
      \typeout{DEBUG: Comparing with institute 3: "\tempinst"}
      \ifx\tempinst\newinst
        \xdef\currentinstnum{3}
        \typeout{DEBUG: Found match at institute 3}
      \fi
    \fi
  \fi

  % Check institute 4
  \ifnum\currentinstnum=0
    \ifnum\theinstitutecount>3
      \expandafter\edef\expandafter\tempinst\expandafter{\csname institute@4\endcsname}
      \typeout{DEBUG: Comparing with institute 4: "\tempinst"}
      \ifx\tempinst\newinst
        \xdef\currentinstnum{4}
        \typeout{DEBUG: Found match at institute 4}
      \fi
    \fi
  \fi

  % If not found, add as new institute
  \ifnum\currentinstnum=0
    \stepcounter{institutecount}
    \expandafter\xdef\csname institute@\theinstitutecount\endcsname{#3}
    \xdef\currentinstnum{\theinstitutecount}
    \typeout{DEBUG: Creating new institute \theinstitutecount: "#3"}
  \fi

  \typeout{DEBUG: Final assignment - institute number: \currentinstnum}

  % Store this author's information
  \expandafter\gdef\csname author@\theauthorcount @presenter\endcsname{#1}
  \expandafter\gdef\csname author@\theauthorcount @name\endcsname{#2}
  \expandafter\gdef\csname author@\theauthorcount @institute\endcsname{#3}
  \expandafter\xdef\csname author@\theauthorcount @institutenumber\endcsname{\currentinstnum}
  \typeout{DEBUG: Stored author \theauthorcount (#2) with institute number \currentinstnum}
  \expandafter\gdef\csname author@\theauthorcount @department\endcsname{#4}
  \expandafter\gdef\csname author@\theauthorcount @email\endcsname{#5}
  \expandafter\gdef\csname author@\theauthorcount @telephone\endcsname{#6}
  \expandafter\gdef\csname author@\theauthorcount @picture\endcsname{#7}
  \expandafter\gdef\csname author@\theauthorcount @qrcode\endcsname{#8}

  % If this is the presenter, store presenter info
  \ifthenelse{\equal{#1}{true}}{
    \gdef\presenterinfo{\theauthorcount}
  }{}
}

% Function to get all author names with institute numbers
\newcommand{\getallauthornameswithinstnumbers}{
  \ifnum\value{authorcount}>0
    \!\!\!\!\getauthornamewithinstnumber{1}\!\!%
    \ifnum\value{authorcount}>1
      \newcount\tempcounter
      \tempcounter=2
      \loop
        \ifnum\tempcounter>\value{authorcount}
        \else
          ,\!\!\getauthornamewithinstnumber{\the\tempcounter}\!\!%
          \advance\tempcounter by 1
      \repeat
    \fi
  \fi
}

% Helper function to get single author name with institute number
\newcommand{\getauthornamewithinstnumber}[1]{
  \typeout{DEBUG: Displaying author #1 - name: \csname author@#1@name\endcsname, institute number: \csname author@#1@institutenumber\endcsname}
  % Check if this author is a presenter and underline if true
  \edef\checkpresenter{\csname author@#1@presenter\endcsname}%
  \ifthenelse{\equal{\checkpresenter}{true}}{%
    \underline{\csname author@#1@name\endcsname}$^{\csname author@#1@institutenumber\endcsname}$%
  }{%
    \csname author@#1@name\endcsname$^{\csname author@#1@institutenumber\endcsname}$%
  }%
}

% Function to get all institutes with numbers
\newcommand{\getallinstituteswithnumbers}{
  \ifnum\value{institutecount}>0
    $^{1}$\csname institute@1\endcsname%
    \ifnum\value{institutecount}>1
      \newcount\tempinstcounter
      \tempinstcounter=2
      \loop
        \ifnum\tempinstcounter>\value{institutecount}
        \else
          \par$^{\the\tempinstcounter}$\csname institute@\the\tempinstcounter\endcsname%
          \advance\tempinstcounter by 1
      \repeat
    \fi
  \fi
}

% Function to get short presenter names (first letter + last name) for footline
\newcommand{\shortpresenter}{%
  % Simple approach - just hard-code the presenters for now
  \newif\iffirstpresenter%
  \firstpresentertrue%
  % Check author 1
  \ifcsname author@1@presenter\endcsname%
    \edef\checkpresenter{\csname author@1@presenter\endcsname}%
    \ifthenelse{\equal{\checkpresenter}{true}}{%
      \iffirstpresenter%
        \firstpresenterfalse%
      \else%
        , %
      \fi%
      \getshortname{\csname author@1@name\endcsname}%
    }{}%
  \fi%
  % Check author 2
  \ifcsname author@2@presenter\endcsname%
    \edef\checkpresenter{\csname author@2@presenter\endcsname}%
    \ifthenelse{\equal{\checkpresenter}{true}}{%
      \iffirstpresenter%
        \firstpresenterfalse%
      \else%
        , %
      \fi%
      \getshortname{\csname author@2@name\endcsname}%
    }{}%
  \fi%
  % Check author 3
  \ifcsname author@3@presenter\endcsname%
    \edef\checkpresenter{\csname author@3@presenter\endcsname}%
    \ifthenelse{\equal{\checkpresenter}{true}}{%
      \iffirstpresenter%
        \firstpresenterfalse%
      \else%
        , %
      \fi%
      \getshortname{\csname author@3@name\endcsname}%
    }{}%
  \fi%
  % Check author 4
  \ifcsname author@4@presenter\endcsname%
    \edef\checkpresenter{\csname author@4@presenter\endcsname}%
    \ifthenelse{\equal{\checkpresenter}{true}}{%
      \iffirstpresenter%
        \firstpresenterfalse%
      \else%
        , %
      \fi%
      \getshortname{\csname author@4@name\endcsname}%
    }{}%
  \fi%
}

\newcommand{\getshortname}[1]{%
  \StrBefore{#1}{ }[\FirstName]%
  \StrBehind{#1}{ }[\LastName]%
  \StrLeft{\FirstName}{1}[\Initial]%
  \Initial.\ \LastName%
}

% Helper function to abbreviate first name (simple approach)
\def\abbreviatefirstname#1 #2\relax{%
  #1.~#2%
}


