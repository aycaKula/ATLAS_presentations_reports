\mode<presentation>

% see http://www.uni-stuttgart.de/more/corporate_design/cd-dateien/Uni_Stuttgart_CD-Manual_2016_klein.pdf
\definecolor{uniSblue}{RGB}{0,81,158}
\definecolor{uniSlightblue}{RGB}{0,190,255}
\definecolor{uniSgray}{RGB}{62, 68, 76}
\definecolor{uniSyellow}{RGB}{255, 213, 0}

% ATLAS General
\definecolor{General}{RGB}{34, 42, 53}

% ATLAS Project area A
\definecolor{AreaAred}{RGB}{186, 74, 50}
\definecolor{AreaAlightred}{RGB}{242, 220, 215}

% ATLAS Project area B
\definecolor{AreaBgreen}{RGB}{65, 117, 1}
\definecolor{AreaBlightgreen}{RGB}{207, 220, 191}

% ATLAS Project area C
\definecolor{AreaCblue}{RGB}{7, 77, 109}
\definecolor{AreaClightblue}{RGB}{193, 210, 218}

% ATLAS Support projects
\definecolor{Supportgrey}{RGB}{128, 128, 128}
\definecolor{Supportlightgrey}{RGB}{197, 197, 197}

% colors not covered by CD but still useful
\definecolor{uniSred}{RGB}{230, 0, 50}
\definecolor{uniSgreen}{RGB}{0, 200, 50}

\setbeamercolor{normal text}{fg=General}

\setbeamercolor{alerted text}{fg=uniSred}

\setbeamercolor{structure}{fg=uniSblue}

\setbeamercolor{itemize item}{fg=uniSblue}

\setbeamercolor{palette primary}{bg=General!20,fg=General}
\setbeamercolor{palette secondary}{bg=General,fg=white}
\setbeamercolor{palette tertiary}{fg=white}
\setbeamercolor{palette quaternary}{fg=uniSblue}

\setbeamercolor{titlelike}{parent=palette quaternary}

\setbeamercolor{block title}{fg=white,bg=General}
\setbeamercolor{block body}{bg=General!20,fg=General}

\setbeamercolor{block title alerted}{fg=white,bg=uniSred}
\setbeamercolor{block body alerted}{bg=General!20,fg=General}

\setbeamercolor{block title example}{fg=white,bg=uniSgreen}
\setbeamercolor{block body example}{bg=General!20,fg=General}

\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

% \setbeamercolor{frametitle}{bg=uniSblue,fg=white}
\setbeamercolor{frametitle}{bg=white,fg=General} % background color title
\setbeamercolor{framesubtitle}{bg=white,fg=General}

% make title page transparent in order to make background images work
\setbeamertemplate{title page}[default]
\setbeamercolor{title}{bg=}

\mode
<all>
