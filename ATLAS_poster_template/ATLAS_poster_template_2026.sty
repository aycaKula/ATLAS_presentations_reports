% =============================================================================
% ATLAS_poster_template_2026.sty
% ATLAS poster template — layout, colors, and rendering macro.
%
% Usage in your .tex file:
%   \usepackage[A,##]{ATLAS_poster_template_2024}   % or [B,##] or [C,##] or [INF] or [OE] or [Z], ## = project number
%
% Package options:
%   A  (default)  	Red theme   — Project Area A
%   B             	Green theme — Project Area B
%   C             	Blue theme  — Project Area C
%   INF, OE, Z 	Grey theme — Support Projects
%
% After loading, fill the five content hooks then call \makemyposter:
%   \renewcommand{\BackgroundContent}{...}
%   \renewcommand{\ObjectivesContent}{...}
%   \renewcommand{\MethodsContent}{...}
%   \renewcommand{\CollaborationsContent}{...}
%   \renewcommand{\ResearchContent}{...}
%   \makemyposter
% =============================================================================

\ProvidesPackage{ATLAS_poster_template_2026}[2026/02/27 ATLAS Poster Template]

\RequirePackage{tikz}
\RequirePackage{ifthen}
\RequirePackage{xcolor}
\RequirePackage{datetime2}

% --- Package options: \usepackage[A,02]{poster_template} --------------------
% First option  : A / B / C  — selects the colour theme
% Second option : anything else (e.g. 02) — stored as the subproject code
\newcommand{\pt@area}{A}       % default area
\newcommand{\pt@subproject}{}  % default subproject (empty)

\DeclareOption{A}{\renewcommand{\pt@area}{A}}
\DeclareOption{B}{\renewcommand{\pt@area}{B}}
\DeclareOption{C}{\renewcommand{\pt@area}{C}}
\DeclareOption{INF}{\renewcommand{\pt@area}{INF}}
\DeclareOption{OE}{\renewcommand{\pt@area}{OE}}
\DeclareOption{Z}{\renewcommand{\pt@area}{Z}}
\DeclareOption*{\edef\pt@subproject{\CurrentOption}}
\ProcessOptions\relax

% Public macros
\newcommand{\ProjectArea}{\pt@area}
\newcommand{\SubProject}{\pt@subproject}

% --- Institute logos (primary and optional secondary) ----------------------
% \pt@logoA is set eagerly at load time so it expands to a plain string
% inside \includegraphics{} — avoids the \endcsname error from lazy \ifthenelse.
\newcommand{\pt@logoA}{logos/uni_stuttgart.pdf}% default
% -------- Area A --------
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{01}}{\renewcommand{\pt@logoA}{logos/ITheoC.png}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{02}}{\renewcommand{\pt@logoA}{logos/IAG.png}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{03}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{04}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{05}}{\renewcommand{\pt@logoA}{logos/IFR.png}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{06}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
% -------- Area B --------
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{01}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{03}}{\renewcommand{\pt@logoA}{logos/IWS.png}}{}
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{04}}{\renewcommand{\pt@logoA}{logos/ITLR.png}}{}
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{05}}{\renewcommand{\pt@logoA}{logos/IPV.png}}{}
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{06}}{\renewcommand{\pt@logoA}{logos/BartzGroup.pdf}}{}
% -------- Area C --------
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{01}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{02}}{\renewcommand{\pt@logoA}{logos/DLR.pdf}}{}
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{03}}{\renewcommand{\pt@logoA}{logos/ILH.png}}{}
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{04}}{\renewcommand{\pt@logoA}{logos/ILS.png}}{}
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{05}}{\renewcommand{\pt@logoA}{logos/INS.png}}{}
\ifthenelse{\equal{\pt@area}{C}\AND\equal{\pt@subproject}{06}}{\renewcommand{\pt@logoA}{logos/GIS.png}}{}
% -------- Support Project --------
\ifthenelse{\equal{\pt@area}{INF}}{\renewcommand{\pt@logoA}{logos/IWS.png}}{}
\ifthenelse{\equal{\pt@area}{OE}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{Z}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
% Public alias
\newcommand{\InstituteLogoOne}{\pt@logoA}

% --- Secondary logo (\pt@logoB) — empty means no second logo ---
% Uses \def (not \newcommand) so that \ifx\pt@logoB\empty works correctly.
\def\pt@logoB{}% default: no secondary logo
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{01}}{\def\pt@logoB{logos/FMQ.png}}{}
\ifthenelse{\equal{\pt@area}{A}\AND\equal{\pt@subproject}{02}}{\def\pt@logoB{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{B}\AND\equal{\pt@subproject}{03}}{\def\pt@logoB{logos/IRS.pdf}}{}
\ifthenelse{\equal{\pt@area}{INF}}{\renewcommand{\pt@logoA}{logos/IRS.pdf}}{}
\newcommand{\InstituteLogoTwo}{\pt@logoB}% public alias

