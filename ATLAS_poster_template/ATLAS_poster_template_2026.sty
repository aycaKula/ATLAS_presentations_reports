% --- Itemize bullet: small filled square in the theme's primary colour -------
\setbeamertemplate{itemize item}{\color{PrimaryColor}\rule[0.35ex]{0.9ex}{0.9ex}}
\setbeamertemplate{itemize subitem}{\color{PrimaryColor}\rule[0.35ex]{0.7ex}{0.7ex}}
\setbeamertemplate{itemize subsubitem}{\color{PrimaryColor}\rule[0.35ex]{0.5ex}{0.5ex}}

% =============================================================================
% Layout constants
% Change \BlockGap to rescale all gutters and margins uniformly.
% =============================================================================
\newlength{\BlockGap}           % uniform gap: page margins + inter-block spaces
\setlength{\BlockGap}{15mm}

\newlength{\TopGap}             % gap between header bar bottom and row 1
\setlength{\TopGap}{25mm}

% -- Block inner padding ------------------------------
\newlength{\BlockPad}           % inner padding between block edge and content
\setlength{\BlockPad}{15mm}

\newlength{\ContentTopSkip}     % vertical distance from block top to minipage
\setlength{\ContentTopSkip}{44mm}

% -- Column widths (auto-derived) ---------------------------------------------
\newlength{\ColWidthHalf}       % each column in two-column rows
\setlength{\ColWidthHalf}{\dimexpr(\paperwidth - 3\BlockGap)/2\relax}

\newlength{\ColWidthFull}       % full-width block (Project plan)
\setlength{\ColWidthFull}{\dimexpr\paperwidth - 2\BlockGap\relax}

% Row 1: Background 50%, Objectives 50% of available width
\newlength{\RowOneAvail}
\setlength{\RowOneAvail}{\dimexpr\paperwidth - 3\BlockGap\relax}

\newlength{\ColWidthBackground}
\setlength{\ColWidthBackground}{\dimexpr5\RowOneAvail/10\relax}

\newlength{\ColWidthObjectives}
\setlength{\ColWidthObjectives}{\dimexpr5\RowOneAvail/10\relax}

% Row 2: Methods 50%, Collaborations 50% of available width
\newlength{\RowTwoAvail}
\setlength{\RowTwoAvail}{\dimexpr\paperwidth - 3\BlockGap\relax}

\newlength{\ColWidthMethods}
\setlength{\ColWidthMethods}{\dimexpr5\RowTwoAvail/10\relax}

\newlength{\ColWidthCollaborations}
\setlength{\ColWidthCollaborations}{\dimexpr5\RowTwoAvail/10\relax}

% -- Block minipage dimensions ------------------------------
\newlength{\MiniWidthHalf}
\setlength{\MiniWidthHalf}{\dimexpr\ColWidthHalf - 2\BlockPad\relax}

\newlength{\MiniWidthFull}
\setlength{\MiniWidthFull}{\dimexpr\ColWidthFull - 2\BlockPad\relax}

\newlength{\MiniWidthBackground}
\setlength{\MiniWidthBackground}{\dimexpr\ColWidthBackground - 2\BlockPad\relax}

\newlength{\MiniWidthObjectives}
\setlength{\MiniWidthObjectives}{\dimexpr\ColWidthObjectives - 2\BlockPad\relax}

\newlength{\MiniWidthMethods}
\setlength{\MiniWidthMethods}{\dimexpr\ColWidthMethods - 2\BlockPad\relax}

\newlength{\MiniWidthCollaborations}
\setlength{\MiniWidthCollaborations}{\dimexpr\ColWidthCollaborations - 2\BlockPad\relax}

\newlength{\TotalHeightRows}
\setlength{\TotalHeightRows}{888.54mm}

\newlength{\HeightRowOne}
\setlength{\HeightRowOne}{\dimexpr3\TotalHeightRows/10\relax}

\newlength{\HeightRowTwo}
\setlength{\HeightRowTwo}{\dimexpr3\TotalHeightRows/10\relax}

\newlength{\HeightRowThree}
\setlength{\HeightRowThree}{\dimexpr4\TotalHeightRows/10\relax}

\newlength{\MiniHeightRowOne}   % row 1 block height: 258.440mm
%\setlength{\MiniHeightRowOne}{\dimexpr 258.440mm - \ContentTopSkip - \BlockPad\relax}
\setlength{\MiniHeightRowOne}{\dimexpr \HeightRowOne - \ContentTopSkip - \BlockPad\relax}

\newlength{\MiniHeightRowTwo}   % row 2 block height: 289.310mm
%\setlength{\MiniHeightRowTwo}{\dimexpr 289.310mm - \ContentTopSkip - \BlockPad\relax}
\setlength{\MiniHeightRowTwo}{\dimexpr \HeightRowTwo - \ContentTopSkip - \BlockPad\relax}

\newlength{\MiniHeightRowThree} % row 3 block height: 340.790mm
%\setlength{\MiniHeightRowThree}{\dimexpr 340.790mm - \ContentTopSkip - \BlockPad\relax}
\setlength{\MiniHeightRowThree}{\dimexpr \HeightRowThree - \ContentTopSkip - \BlockPad\relax}

% -- Row y-positions (distance from page north) --------------------------------
\newlength{\RowOneY}
\setlength{\RowOneY}{\dimexpr 161.960mm + \TopGap\relax}

\newlength{\RowTwoY}
%\setlength{\RowTwoY}{\dimexpr\RowOneY + 258.440mm + \BlockGap\relax}
\setlength{\RowTwoY}{\dimexpr\RowOneY + \HeightRowOne + \BlockGap\relax}

\newlength{\RowThreeY}
%\setlength{\RowThreeY}{\dimexpr\RowTwoY + 289.310mm + \BlockGap\relax}
\setlength{\RowThreeY}{\dimexpr\RowTwoY + \HeightRowTwo + \BlockGap\relax}

% -- Right-column x-start positions -------------------------------------------
\newlength{\ColRightX}
\setlength{\ColRightX}{\dimexpr\BlockGap + \ColWidthHalf + \BlockGap\relax}

\newlength{\ObjectivesX}
\setlength{\ObjectivesX}{\dimexpr\BlockGap + \ColWidthBackground + \BlockGap\relax}

\newlength{\CollaborationsX}
\setlength{\CollaborationsX}{\dimexpr\BlockGap + \ColWidthMethods + \BlockGap\relax}


% =============================================================================
% Content hooks
% User overrides these in poster.tex with \renewcommand.
% The content is placed INSIDE the minipage; the wrapper is the template's job.
% =============================================================================
\newcommand{\PosterDate}{}

\newcommand{\BackgroundContent}{}
\newcommand{\ObjectivesContent}{}
\newcommand{\MethodsContent}{}
\newcommand{\CollaborationsContent}{}
\newcommand{\ResearchContent}{}

% =============================================================================
% \makemyposter
% Renders the full poster layout. Call inside \begin{frame}[t]...\end{frame}.
% =============================================================================
\newcommand{\makemyposter}{%
    %
    % --- Header bar ---
    \begin{tikzpicture}[remember picture,overlay]
      \fill[PrimaryColor]
        ([yshift=-44.700mm]current page.north west)
        rectangle ([yshift=-161.96mm]current page.north east);
    \end{tikzpicture}%
    %
    % --- ATLAS logo ---
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=center] (atlas)
        at ([xshift=81.625mm, yshift=-101.515mm]current page.north west)
        {\includegraphics[width=150mm]{logos/ATLAS_Logo.png}};
      \draw[line width=5mm, PrimaryColor] (atlas.center) circle[radius=75.145mm];
    \end{tikzpicture}%
    %
    % --- Subproject logo ---
    \begin{tikzpicture}[remember picture,overlay]
      \begin{scope}
        \clip ([xshift=759.475mm, yshift=-101.515mm]current page.north west)
          circle[radius=73.145mm];
        \node[anchor=center]
          at ([xshift=759.475mm, yshift=-101.515mm]current page.north west)
          {\includegraphics[width=145mm]{logos/\ProjectArea\SubProject_noring.pdf}};
      \end{scope}
      \draw[line width=5mm, PrimaryColor]
        ([xshift=759.475mm, yshift=-101.515mm]current page.north west)
        circle[radius=75.145mm];
    \end{tikzpicture}%
    %
    % --- Project area badge ---
    \begin{tikzpicture}[remember picture,overlay]
      \draw[line width=2.5mm, PrimaryMuted, fill=PrimaryColor]
        ([xshift=670.030mm, yshift=-141.520mm]current page.north west)
        circle[radius=34.985mm];
      \node[anchor=center, text=white, font=\bfseries\fontsize{90pt}{90pt}\selectfont]
        at ([xshift=670.030mm, yshift=-141.520mm]current page.north west)
        {\ProjectArea\SubProject};
    \end{tikzpicture}%
    %
    % --- Poster title (uses \title{} set in the .tex) ---
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=center, align=center, text=white, font=\bfseries\fontsize{66pt}{66pt}\selectfont] (title)
       % at ([xshift=407.053mm, yshift=-95.054mm]current page.north west)
	at ([xshift=407.053mm, yshift=-103.35mm]current page.north west)
        {\PosterTitle};
    \end{tikzpicture}%
    %
    % -- Date (uses \PosterDate{} set in the .tex) ---
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=center, align=center, text=white, font=\fontsize{36pt}{36pt}\selectfont]
      at ([yshift=1.4cm]title.north)
      {\textit{\PosterDate}};
    \end{tikzpicture}%
    %
    % -- Author names (uses \author{} set in the .tex) ---
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=center, align=center, text=white, font=\fontsize{36pt}{36pt}\selectfont]
      at ([yshift=-1.4cm]title.south)
      {\insertauthor,\ProjectLeader};
    \end{tikzpicture}%
    %
    % --- BACKGROUND block ---
    \begin{tikzpicture}[remember picture,overlay]
      \coordinate (start) at ([xshift=\BlockGap, yshift=-\RowOneY]current page.north west);
      \fill[white, rounded corners=13mm]
        (start) rectangle ([xshift=\ColWidthBackground, yshift=-\HeightRowOne]start);
      \node[anchor=north west, text=black, font=\bfseries\fontsize{54pt}{54pt}\selectfont, inner sep=0]
        at ([xshift=\BlockPad, yshift=-\BlockPad]start) {Background};
      \node[anchor=north west, inner sep=0, font=\fontsize{36pt}{36pt}\selectfont]
        at ([xshift=\BlockPad, yshift=-\ContentTopSkip]start)
        {\begin{minipage}[t][\MiniHeightRowOne][t]{\MiniWidthBackground}%
          \BackgroundContent%
        \end{minipage}};
    \end{tikzpicture}%
    %
    % --- OBJECTIVES block ---
    \begin{tikzpicture}[remember picture,overlay]
      \coordinate (start) at ([xshift=\ObjectivesX, yshift=-\RowOneY]current page.north west);
      \fill[white, rounded corners=13mm]
        (start) rectangle ([xshift=\ColWidthObjectives, yshift=-\HeightRowOne]start);
      \node[anchor=north west, text=black, font=\bfseries\fontsize{54pt}{54pt}\selectfont, inner sep=0]
        at ([xshift=\BlockPad, yshift=-\BlockPad]start) {Objectives};
      \node[anchor=north west, inner sep=0, font=\fontsize{36pt}{36pt}\selectfont]
        at ([xshift=\BlockPad, yshift=-\ContentTopSkip]start)
        {\begin{minipage}[t][\MiniHeightRowOne][t]{\MiniWidthObjectives}%
          \ObjectivesContent%
        \end{minipage}};
    \end{tikzpicture}%
    %
    % --- METHODS block ---
    \begin{tikzpicture}[remember picture,overlay]
      \coordinate (start) at ([xshift=\BlockGap, yshift=-\RowTwoY]current page.north west);
      \fill[white, rounded corners=13mm]
%        (start) rectangle ([xshift=\ColWidthCollaborations, yshift=-289.310mm]start);
        (start) rectangle ([xshift=\ColWidthMethods, yshift=-\HeightRowTwo]start);
      \node[anchor=north west, text=black, font=\bfseries\fontsize{54pt}{54pt}\selectfont, inner sep=0]
        at ([xshift=\BlockPad, yshift=-\BlockPad]start) {Methods};
      \node[anchor=north west, inner sep=0, font=\fontsize{36pt}{36pt}\selectfont]
        at ([xshift=\BlockPad, yshift=-\ContentTopSkip]start)
        {\begin{minipage}[t][\MiniHeightRowTwo][t]{\MiniWidthMethods}%
          \MethodsContent%
        \end{minipage}};
    \end{tikzpicture}%
    %
    % --- COLLABORATIONS block ---
    \begin{tikzpicture}[remember picture,overlay]
      \coordinate (start) at ([xshift=\CollaborationsX, yshift=-\RowTwoY]current page.north west);
      \fill[white, rounded corners=13mm]
%        (start) rectangle ([xshift=\ColWidthOutlook, yshift=-289.310mm]start);
        (start) rectangle ([xshift=\ColWidthCollaborations, yshift=-\HeightRowTwo]start);
      \node[anchor=north west, text=black, font=\bfseries\fontsize{54pt}{54pt}\selectfont, inner sep=0]
        at ([xshift=\BlockPad, yshift=-\BlockPad]start) {Collaborations};
      \node[anchor=north west, inner sep=0, font=\fontsize{36pt}{36pt}\selectfont]
        at ([xshift=\BlockPad, yshift=-\ContentTopSkip]start)
        {\begin{minipage}[t][\MiniHeightRowTwo][t]{\MiniWidthCollaborations}%
          \CollaborationsContent%
        \end{minipage}};
    \end{tikzpicture}%
    %
    % --- RESEARCH block ---
    \begin{tikzpicture}[remember picture,overlay]
      \coordinate (start) at ([xshift=\BlockGap, yshift=-\RowThreeY]current page.north west);
      \fill[white, rounded corners=13mm]
 %       (start) rectangle ([xshift=\ColWidthFull, yshift=-340.790mm]start);
       (start) rectangle ([xshift=\ColWidthFull, yshift=-\HeightRowThree]start);
      \node[anchor=north west, text=black, font=\bfseries\fontsize{54pt}{54pt}\selectfont, inner sep=0]
        at ([xshift=\BlockPad, yshift=-\BlockPad]start) {Research Highlights};
      \node[anchor=north west, inner sep=0, font=\fontsize{36pt}{36pt}\selectfont]
        at ([xshift=\BlockPad, yshift=-\ContentTopSkip]start)
        {\begin{minipage}[t][\MiniHeightRowThree][t]{\MiniWidthFull}%
          \ResearchContent%
        \end{minipage}};
    \end{tikzpicture}%
    %
    % --- Footer ---
    % Primary institute logo (always shown)
