% --- Named colors (base palette) ---------------------------------------------
\definecolor{atlasRed}{HTML}{BA4A32}
\definecolor{atlasRedMuted}{HTML}{F2DCD7}
\definecolor{atlasGreen}{HTML}{417501}
\definecolor{atlasGreenMuted}{HTML}{CFDCBF}
\definecolor{atlasBlue}{HTML}{074D6D}
\definecolor{atlasBlueMuted}{HTML}{C1D2DA}
\definecolor{atlasGrey}{HTML}{808080}
\definecolor{atlasGreyMuted}{HTML}{C5C5C5}
\definecolor{atlasGreyDark}{HTML}{222A35}

% --- Theme aliases derived from the chosen project area ----------------------
\ifthenelse{\equal{\pt@area}{A}}{%
  \colorlet{PrimaryColor}{atlasRed}%
  \colorlet{PrimaryMuted}{atlasRedMuted}%
}{}%
\ifthenelse{\equal{\pt@area}{B}}{%
  \colorlet{PrimaryColor}{atlasGreen}%
